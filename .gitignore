# Dependency directories (ESSENTIAL to avoid pushing gigabytes of local packages)
node_modules/
.pnp
.pnp.js

# Environment variables and local configs (CRITICAL to prevent credential leaks)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
cypress.env.json

# Cypress test fixtures containing credentials or sensitive data
cypress/fixtures/users.json

# Cypress execution artifacts (Generated automatically during test runs)
cypress/screenshots/
cypress/videos/
cypress/downloads/

# Debug and error logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor and OS system files
.DS_Store
Thumbs.db
.vscode/
.idea/